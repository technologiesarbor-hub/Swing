# Override the (company) global registry for this project only.
# The global ~/.npmrc points to an internal artifactory which is not
# reachable from arbitrary networks; this project pulls from the public
# npm registry instead.
registry=https://registry.npmjs.org/
always-auth=false
strict-ssl=true

# Allow Expo / Metro / Reanimated to run their install scripts. The
# global config sets `ignore-scripts=true` for safety; we narrow that
# down with pnpm's `onlyBuiltDependencies` mechanism via the project's
# approve-builds list (run `pnpm approve-builds` if a new native dep
# asks for it).
ignore-scripts=false
