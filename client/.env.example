# Copy to client/.env — API base URL for the Go backend.
# Find laptop IP: hostname -I | awk '{print $1}'

# Physical phone (same Wi‑Fi / hotspot as laptop)
EXPO_PUBLIC_API_URL=http://172.20.10.2:8080

# Google OAuth — see client/GOOGLE-AUTH-SETUP.md if you see "Access blocked"
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# Android emulator only
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
